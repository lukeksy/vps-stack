# =============================================================================
# .env.example — Template variables d'environnement
# Copier ce fichier en .env et remplir toutes les valeurs
# NE JAMAIS commiter le fichier .env
# =============================================================================


# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------

# Nom de la base de données n8n
POSTGRES_DB=n8n

# Utilisateur PostgreSQL (choisir un nom non générique)
POSTGRES_USER=n8n_user

# Mot de passe fort (générer avec : openssl rand -base64 32)
POSTGRES_PASSWORD=CHANGE_ME


# -----------------------------------------------------------------------------
# n8n
# -----------------------------------------------------------------------------

# Clé de chiffrement des credentials n8n (générer avec : openssl rand -hex 32)
# ATTENTION : si perdue, tous les credentials stockés sont irrécupérables
N8N_ENCRYPTION_KEY=CHANGE_ME

# Authentification basique pour l'interface n8n
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME


# -----------------------------------------------------------------------------
# APIs externes (utilisées dans les workflows n8n)
# Stocker les valeurs dans Proton Pass, les référencer ici
# -----------------------------------------------------------------------------

# Notion — clé d'intégration interne
# https://www.notion.so/my-integrations
# NOTION_API_KEY=secret_xxx

# Gmail — OAuth configuré directement dans n8n (pas de variable nécessaire)

# Todoist — token API
# https://app.todoist.com/app/settings/integrations/developer
# TODOIST_API_TOKEN=xxx

# Claude (Anthropic) — clé API pour l'AI Agent
# https://console.anthropic.com/keys
# ANTHROPIC_API_KEY=sk-ant-xxx

# Ntfy — token d'authentification (si accès restreint)
# NTFY_TOKEN=xxx
